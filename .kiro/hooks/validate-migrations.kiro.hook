{
  "enabled": true,
  "name": "Validate Migrations",
  "description": "Apply database migrations by running npm run db:migrate",
  "version": "1",
  "when": {
    "type": "userTriggered"
  },
  "then": {
    "type": "askAgent",
    "prompt": "Run `npm run db:migrate` to apply the database migrations and verify they execute successfully"
  },
  "workspaceFolderName": "parallel-app",
  "shortName": "validate-migrations"
}
